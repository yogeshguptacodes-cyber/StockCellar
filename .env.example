# Copy this file to `.env`, fill in values, then restart the dev server.
# EXPO_PUBLIC_* variables are inlined into the client bundle at build time —
# never put true secrets here once the app ships publicly.

# Google Gemini API key — enables real AI sheet extraction in the Scanner.
# Leave empty to use the built-in mock extraction.
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional: override the Gemini model used for extraction.
EXPO_PUBLIC_GEMINI_MODEL=gemini-3.5-flash
